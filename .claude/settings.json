{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(git push --force:*)",
      "Bash(git reset --hard:*)",
      "Edit(target/**)",
      "Edit(LICENSE)",
      "Edit(Cargo.lock)"
    ]
  },
  "env": {
    "CONVERGIO_DEFAULT_DB": "sqlite://./.convergio-dev.db",
    "RUST_BACKTRACE": "1"
  }
}
